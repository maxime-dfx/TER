# ==============================================================================
# 1. ARTEFACTS DE COMPILATION C++
# ==============================================================================
# On ne versionne JAMAIS ce qui est généré par le compilateur
*.o
*.obj
*.exe
*.out
*.dll
*.so
*.a

# Dossiers de build spécifiques à ton architecture
core/bin/
core/finite_elements/obj/
core/traitement_image/obj/

# ==============================================================================
# 2. ENVIRONNEMENT PYTHON
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so

# Environnements virtuels (si tu utilises pip/conda localement)
.env/
.venv/
env/
venv/
ENV/

# ==============================================================================
# 3. MÉCANIQUE NUMÉRIQUE & OUTPUTS (GMSH / PARAVIEW)
# ==============================================================================
# Les résultats de simulation ne doivent pas polluer le dépôt. 
# Seuls les scripts permettant de les reproduire comptent.
*.vtk
*.vtu
*.pvd

# Ignorer les répertoires de sortie de ton solveur
data/outputs/
workspace/

# Ignorer les maillages générés dynamiquement par tes scripts
# (Note : On garde data/raw/geo/maillage.geo car c'est un code source, 
# mais on ignore les .mesh créés à la volée s'ils sont lourds)
*.msh
workspace/**/*.mesh

# Ignorer les graphiques générés (à moins que tu ne rédiges ton rapport en LaTeX via Git)
results/*.png

# ==============================================================================
# 4. SYSTÈME D'EXPLOITATION & IDE
# ==============================================================================
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db